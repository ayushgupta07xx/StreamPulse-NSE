# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Discord webhook for Alertmanager notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANGE_ME

# Generator defaults
GENERATOR_SPEED=10            # 1, 10, 100, or max
GENERATOR_TICKERS=ALL         # ALL or comma-separated subset, e.g. TCS,RELIANCE

# ClickHouse (local dev defaults)
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
